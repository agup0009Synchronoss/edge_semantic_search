# ===== Gradle build outputs & caches =====
.gradle/
build/
*.iml

# ===== Android SDK / local config (machine-specific, never commit) =====
local.properties

# ===== IDE files =====
.idea/
*.iws
*.ipr

# ===== Kotlin / JVM caches =====
.kotlin/

# ===== AI assistant settings =====
.claude/

# ===== ML model assets =====
# All model assets are committed (text ~15 MB, vision ~33 MB, tokenizer ~1.3 MB)
# They are checked in so the app builds and runs without running export_split.py

# ===== Python tooling outputs & caches =====
tools/out/
tools/__pycache__/
*.pyc
*.pyo
